{
  "name": "waskostetmich",
  "version": "0.1.0",
  "private": false,
  "description": "Deckt Abos & wiederkehrende Abbuchungen aus deinem deutschen Kontoauszug auf – inkl. schleichender Preiserhöhungen. 100% im Browser, keine Daten verlassen dein Gerät.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "kontoauszug",
    "abo",
    "subscription",
    "recurring",
    "privacy",
    "client-side",
    "csv",
    "sparkasse",
    "dkb",
    "ing",
    "fintech"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:standalone": "tsc --noEmit && vite build --mode standalone",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "analyze": "tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
